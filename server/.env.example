# ===== DATABASE CONFIGURATION =====
# MySQL connection settings
DB_HOST=localhost          # MySQL server host
DB_PORT=3306               # MySQL port (default: 3306)
DB_USER=root               # MySQL username
DB_PASSWORD=               # MySQL password (empty if no password)
DB_NAME=noma_pos           # Database name

# ===== SERVER CONFIGURATION =====
# Backend server settings
PORT=5000                  # Server port (change if 5000 is busy)
NODE_ENV=development       # Environment: development or production

# ===== SECURITY CONFIGURATION =====
# JWT Secret for authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_this

# ===== EMAIL CONFIGURATION (Optional) =====
# For sending emails (future feature)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ===== PAYMENT GATEWAY (Optional) =====
# For real QRIS integration
# MIDTRANS_SERVER_KEY=your_midtrans_key
# MIDTRANS_CLIENT_KEY=your_client_key

# ===== LOGGING =====
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ===== CORS CONFIGURATION =====
# For production, specify exact origin
# CORS_ORIGIN=https://yourdomain.com

# ===== FILE UPLOAD =====
# Maximum file size for uploads (in MB)
MAX_UPLOAD_SIZE=2

# ===== API RATE LIMITING (Optional) =====
# Requests per minute
RATE_LIMIT=100
